# ─────────────────────────────────────────────
# Wanderlog — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ─────────────────────────────────────────────

# IBM Cloud API Key (from cloud.ibm.com → Manage → Access → API Keys)
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID (from watsonx.ai → Projects → your project → Manage → General)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Watsonx.ai service URL (region-specific)
# AU Sydney : https://au-syd.ml.cloud.ibm.com
# US South  : https://us-south.ml.cloud.ibm.com
# EU DE     : https://eu-de.ml.cloud.ibm.com
# EU GB     : https://eu-gb.ml.cloud.ibm.com
# JP Tokyo  : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Granite model ID — use the exact ID from your Watsonx.ai region
# Available options (check https://dataplatform.cloud.ibm.com/wx/samples/models):
#   ibm/granite-3-8b-instruct      (AU Sydney, recommended)
#   ibm/granite-3-3-8b-instruct    (US South / EU regions)
#   ibm/granite-13b-instruct-v2
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Web server port (default: 3000)
PORT=3000
