# ─────────────────────────────────────────────
# Wanderlog — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ─────────────────────────────────────────────

# IBM Cloud API Key (from cloud.ibm.com → Manage → Access → API Keys)
IBM_CLOUD_API_KEY=G4r2Ladxxngc_KC9J-w9P-b982L3qhiX295hXPt8kpEw

# IBM Watsonx.ai Project ID (from watsonx.ai → Projects → your project → Manage → General)
WATSONX_PROJECT_ID=181397f3-0124-4a17-8754-375ac200cd4c

# Watsonx.ai service URL (region-specific)
# US South  : https://us-south.ml.cloud.ibm.com
# EU DE     : https://eu-de.ml.cloud.ibm.com
# EU GB     : https://eu-gb.ml.cloud.ibm.com
# JP Tokyo  : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Granite model ID — Granite 3.3 8B Instruct (default)
# Available options:
#   ibm/granite-3-3-8b-instruct   (fast, recommended)
#   ibm/granite-3-1-8b-instruct
#   ibm/granite-3-0-8b-instruct
#WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Web server port (default: 3000)
PORT=3000
